{
  "name": "japanpost-react",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/cp949/japanpost-react.git"
  },
  "homepage": "https://github.com/cp949/japanpost-react",
  "bugs": {
    "url": "https://github.com/cp949/japanpost-react/issues"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "pnpm demo:full",
    "release:package": "pnpm --dir packages/japanpost-react release",
    "readme:package": "node scripts/generate-package-readme.mjs",
    "readme:package:check": "node scripts/generate-package-readme.mjs --check",
    "test:workspace": "vitest run --config tests/vitest.config.ts",
    "demo:dev": "pnpm --filter demo dev",
    "demo:full": "node ./scripts/dev-demo.mjs",
    "demo:build": "pnpm --filter demo build",
    "api:dev": "pnpm --filter minimal-api dev",
    "api:check": "node ./scripts/check-api.mjs",
    "api:build": "pnpm --filter minimal-api build",
    "api:check-types": "pnpm --filter minimal-api check-types",
    "test": "node ./scripts/test.mjs",
    "test:package": "pnpm --filter @cp949/japanpost-react test",
    "test:package:unit": "pnpm --filter @cp949/japanpost-react test:unit",
    "verify:release": "pnpm test && pnpm --filter @cp949/japanpost-react test:artifacts",
    "lint": "turbo run lint && biome lint tests",
    "lint:fix": "turbo run lint -- --write --unsafe",
    "format": "biome format --write .",
    "check-types": "turbo run check-types && tsc --noEmit -p tests/tsconfig.json"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "turbo": "^2.8.20",
    "typescript": "6.0.2",
    "vitest": "^4.1.1"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  }
}
