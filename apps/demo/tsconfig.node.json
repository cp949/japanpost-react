{
  "compilerOptions": {
    "composite": true,
    "outDir": "./node_modules/.cache/tsconfig.node",
    "tsBuildInfoFile": "./node_modules/.cache/tsconfig.node/tsconfig.tsbuildinfo",
    "skipLibCheck": true,
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true
  },
  "include": ["vite.config.ts"]
}
