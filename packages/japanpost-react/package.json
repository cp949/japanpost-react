{
  "name": "@cp949/japanpost-react",
  "version": "1.0.5",
  "description": "Headless React hooks and optional components for Japan Post postcode and address search",
  "type": "module",
  "author": "cp949",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/cp949/japanpost-react.git"
  },
  "homepage": "https://github.com/cp949/japanpost-react",
  "bugs": {
    "url": "https://github.com/cp949/japanpost-react/issues"
  },
  "main": "dist/index.es.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.es.js"
    }
  },
  "scripts": {
    "dev": "tsup --config tsup.config.ts --watch",
    "build": "tsup --config tsup.config.ts && node scripts/postbuild-client.mjs",
    "release": "pnpm --dir ../.. readme:package && pnpm --dir ../.. test && pnpm build && pnpm publish --access public",
    "lint": "biome lint .",
    "check-types": "tsc --noEmit",
    "test": "pnpm test:unit",
    "test:artifacts": "pnpm build && vitest run tests/packageArtifacts.test.ts",
    "test:unit": "vitest run --exclude tests/packageArtifacts.test.ts",
    "test:watch": "vitest"
  },
  "keywords": [
    "japan",
    "postcode",
    "postal-code",
    "address",
    "react"
  ],
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.0",
    "typescript": "6.0.2",
    "vitest": "^4.1.1"
  }
}
